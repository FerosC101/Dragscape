rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin: full read access to everything ──────────────────────────────
    // Sign in with admin@dragscape.com to access the research dashboard.
    match /{document=**} {
      allow read: if request.auth != null
                  && request.auth.token.email == 'admin@dragscape.com';
    }

    // ── Regular users: only their own profile ──────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Regular users: only their own game history ─────────────────────────
    match /users/{userId}/gameHistory/{gameId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}

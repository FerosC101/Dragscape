rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
          && (
               request.auth.uid == 'thrco5dFrbgsoH8rh94agFKdyVD2'
            || request.auth.token.email == 'admin@dragscape.com'
          );
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Admin: full read and write access to every document ──────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ── Admin: explicit collectionGroup support for gameHistory ────────────
    // Firebase requires a path-scoped rule for collectionGroup queries.
    // This allows the admin dashboard to run:
    //   getDocs(collectionGroup(db, 'gameHistory'))
    match /{path=**}/gameHistory/{gameId} {
      allow read, write: if isAdmin();
    }

    // ── User profiles ─────────────────────────────────────────────────────
    // Read is public so username look-ups work during login & registration
    // (the requester is not yet authenticated at that point).
    // Only the document owner may write.
    match /users/{userId} {
      allow read:  if true;
      allow write: if isOwner(userId);
    }

    // ── Regular users: own game history sub-collections ────────────────────
    match /users/{userId}/gameHistory/{gameId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/gameHistoryV2/{gameId} {
      allow read, write: if isOwner(userId);
    }
  }
}

